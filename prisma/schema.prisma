generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Track {
  frontend
  backend
}

enum QuestionType {
  concept
  experience
}

enum AnswerFramework {
  PREP
  STAR
}

enum SubscriptionStatus {
  pending
  active
  dormant
  unsubscribed
}

enum DeliveryStatus {
  queued
  sent
  failed
}

enum TokenType {
  verify
  manage
  unsubscribe
}

model Subscriber {
  id               Int               @id @default(autoincrement())
  email            String            @unique
  status           SubscriptionStatus
  consentToReceive Boolean
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  tracks           SubscriberTrack[]
  tokens           SubscriptionToken[]
}

model SubscriberTrack {
  id                   Int                @id @default(autoincrement())
  subscriberId         Int
  track                Track
  status               SubscriptionStatus
  currentQuestionOrder Int                @default(1)
  lastClickedAt        DateTime?
  activatedAt          DateTime?
  dormantAt            DateTime?
  unsubscribedAt       DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  subscriber           Subscriber         @relation(fields: [subscriberId], references: [id])
  deliveries           Delivery[]

  @@unique([subscriberId, track])
}

model Question {
  id                   Int              @id @default(autoincrement())
  track                Track
  category             String
  questionType         QuestionType
  recommendedFramework AnswerFramework
  title                String
  questionText         String
  conceptSummary       String
  modelAnswer          String
  followUps            Json
  questionOrder        Int
  isPublished          Boolean          @default(true)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  deliveries           Delivery[]

  @@unique([track, questionOrder])
}

model Delivery {
  id                Int             @id @default(autoincrement())
  subscriberTrackId Int
  questionId        Int
  status            DeliveryStatus
  sentAt            DateTime?
  clickedAt         DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  subscriberTrack   SubscriberTrack @relation(fields: [subscriberTrackId], references: [id])
  question          Question        @relation(fields: [questionId], references: [id])
}

model SubscriptionToken {
  id           Int       @id @default(autoincrement())
  subscriberId Int
  type         TokenType
  tokenHash    String    @unique
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime  @default(now())
  subscriber   Subscriber @relation(fields: [subscriberId], references: [id])
}
